{
  "name": "omnistage",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "mcp-servers/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace @omnistage/web run dev",
    "build:mcp-dice": "npm run build --workspace @omnistage/mcp-dice-roller",
    "build:mcp-world": "npm run build --workspace @omnistage/mcp-world-tools",
    "build:web": "npm --workspace @omnistage/web run build",
    "build:all": "npm run build:mcp-dice && npm run build:mcp-world && npm run build:web",
    "start:web": "npm --workspace @omnistage/web run start"
  }
}
